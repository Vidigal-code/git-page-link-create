{
  "id": "job-github-style",
  "name": "GitHub Hiring",
  "description": "Clean and readable style for technical job posts.",
  "layout": {
    "style": "stacked",
    "containerMaxWidth": 880,
    "imageShape": "rounded"
  },
  "effects": {
    "backgroundEffect": "grid",
    "hoverEffect": "outline"
  },
  "modes": {
    "light": {
      "background": "#f6f8fa",
      "surface": "#ffffff",
      "text": "#1f2328",
      "mutedText": "#57606a",
      "primary": "#0969da",
      "primaryText": "#ffffff",
      "border": "#d0d7de",
      "chip": "#f3f4f6",
      "shadow": "0 12px 28px rgba(31,35,40,0.12)"
    },
    "dark": {
      "background": "#0d1117",
      "surface": "#161b22",
      "text": "#e6edf3",
      "mutedText": "#9da7b3",
      "primary": "#2f81f7",
      "primaryText": "#0d1117",
      "border": "#30363d",
      "chip": "#21262d",
      "shadow": "0 16px 32px rgba(0,0,0,0.55)"
    }
  }
}
