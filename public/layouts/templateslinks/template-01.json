{
  "id": "github-style",
  "name": "GitHub Style",
  "description": "Clean GitHub-inspired profile layout with strong readability.",
  "layout": {
    "style": "stacked",
    "containerMaxWidth": 520,
    "avatarShape": "rounded"
  },
  "effects": {
    "backgroundEffect": "grid",
    "hoverEffect": "outline"
  },
  "modes": {
    "light": {
      "background": "#f4f7ff",
      "surface": "#ffffff",
      "text": "#1d2a44",
      "mutedText": "#4f607f",
      "primary": "#5b4bff",
      "primaryText": "#ffffff",
      "border": "#d9e1ff",
      "chip": "#edf1ff",
      "shadow": "0 18px 36px rgba(30, 49, 118, 0.16)"
    },
    "dark": {
      "background": "#0f1220",
      "surface": "#171b2f",
      "text": "#e9ecff",
      "mutedText": "#b1b9d8",
      "primary": "#7f73ff",
      "primaryText": "#ffffff",
      "border": "#2a3152",
      "chip": "#232a46",
      "shadow": "0 16px 32px rgba(0, 0, 0, 0.45)"
    }
  }
}
