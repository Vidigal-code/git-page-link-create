{
  "id": "default",
  "name": "Default Theme",
  "author": "Kauan Vidigal",
  "version": "1.0.0",
  "mode": "light",
  "supportsLightAndDarkModes": false,
  "colors": {
    "background": "#FFFFFF",
    "primary": "#0EA5E9",
    "secondary": "#2563EB",
    "text": "#0F172A",
    "textSecondary": "#334155",
    "cardBackground": "#FFFFFF",
    "cardBorder": "#E2E8F0",
    "error": "#DC2626",
    "success": "#16A34A"
  },
  "typography": {
    "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Inter, Roboto, Helvetica, Arial, sans-serif",
    "fontSize": {
      "small": "0.875rem",
      "base": "1rem",
      "medium": "1.125rem",
      "large": "1.25rem",
      "xlarge": "2rem"
    }
  },
  "components": {
    "header": {
      "height": "80px",
      "backgroundColor": "#FFFFFF",
      "borderBottom": "1px solid #E2E8F0"
    },
    "footer": {
      "height": "60px",
      "backgroundColor": "#FFFFFF",
      "borderTop": "1px solid #E2E8F0"
    },
    "card": {
      "borderRadius": "16px",
      "padding": "24px",
      "boxShadow": "0 18px 50px rgba(15, 23, 42, 0.08)"
    },
    "button": {
      "borderRadius": "12px",
      "padding": "10px 18px",
      "border": "1px solid #E2E8F0",
      "hoverGlow": "0 0 0 4px rgba(109, 40, 217, 0.15)"
    },
    "select": {
      "borderRadius": "12px",
      "padding": "10px 40px 10px 16px",
      "border": "1px solid #E2E8F0",
      "backgroundColor": "#FFFFFF",
      "textAlign": "center",
      "iconColor": "#2563EB",
      "hoverBorderColor": "rgba(8, 145, 178, 0.7)",
      "focusBorderColor": "rgba(109, 40, 217, 0.8)",
      "focusGlow": "0 0 0 4px rgba(109, 40, 217, 0.15)"
    },
    "checkbox": {
      "width": "20px",
      "height": "20px",
      "accentColor": "#0EA5E9",
      "borderColor": "#CBD5E1",
      "hoverBorderColor": "rgba(8, 145, 178, 0.7)",
      "checkMarkColor": "#FFFFFF",
      "borderRadius": "6px"
    }
  },
  "animations": {
    "enableTypingEffect": false,
    "enableGlow": false,
    "transitionDuration": "0.22s"
  }
}
